<mujoco model="so_arm100 scene with cameras + cube">
  <!-- scene_cameras.xml（アーム+床+カメラ）に、掴む対象の cube を1個足したもの。
       cube は free joint なので重力で床に乗り、押す/掴むと動く（= dynamic）。
       位置 pos はアームのリーチ内の暫定値。掴めない/映らない場合は pos を調整する。 -->
  <include file="scene_cameras.xml"/>

  <worldbody>
    <body name="cube" pos="0.15 0.0 0.015">
      <freejoint name="cube_free"/>
      <geom name="cube" type="box" size="0.015 0.015 0.015"
            rgba="0.9 0.2 0.2 1" mass="0.02"
            friction="1.0 0.05 0.001"/>
    </body>
  </worldbody>
</mujoco>
