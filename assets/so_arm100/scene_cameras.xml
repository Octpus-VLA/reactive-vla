<mujoco model="so_arm100 scene with cameras">
  <!-- Menagerie の scene.xml（pristine）に SmolVLA 用のオフスクリーンカメラを足したもの。
       upstream の scene.xml は由来保持のため未編集。カメラ位置・向きは暫定値で、
       実機の撮影アングルに合わせて要調整（mujoco.viewer で当たりを付けると早い）。 -->
  <include file="scene.xml"/>

  <worldbody>
    <camera name="cam1" pos="0.4 0.0 0.4" xyaxes="0 -1 0 0.3 0 1"/>
    <camera name="cam2" pos="0.0 0.5 0.4" xyaxes="-1 0 0 0 -0.5 1"/>

    <!-- 操作対象: 2.5cm の赤キューブ。free joint で自由に動く。
         初期位置はアームの作業範囲内の暫定値。掴めない/届かない場合は pos を調整する。
         friction を既定より上げて滑りにくくしている（把持しやすさのため）。 -->
    <body name="cube" pos="0.2 0.0 0.0125">
      <freejoint name="cube_free"/>
      <geom name="cube" type="box" size="0.0125 0.0125 0.0125" rgba="0.85 0.2 0.2 1"
        mass="0.02" friction="1.0 0.05 0.01" condim="4"/>
    </body>
  </worldbody>
</mujoco>
